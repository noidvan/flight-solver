CC      = gcc
CFLAGS  = -O3 -Wall -Wextra -lm

bench_rls_c: bench_rls_c.c
	$(CC) $(CFLAGS) -o $@ $<

.PHONY: run clean all

run: bench_rls_c
	./bench_rls_c

all: bench_rls_c
	@echo "=== C RLS benchmark ==="
	./bench_rls_c
	@echo ""
	@echo "=== Rust RLS benchmark ==="
	cargo build --release --bin bench_rls --manifest-path ../Cargo.toml
	../target/release/bench_rls

clean:
	rm -f bench_rls_c
